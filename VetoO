function getActType(name) {
            const n = name.toLowerCase();
            
            // ترتيب الأولويات مهم هنا
            if (n.includes('test')) return 'type-test'; // أي نشاط فيه اختبار يتلون بالأحمر
            if (n.includes('gr')) return 'type-gr';
            if (n.includes('lis')) return 'type-lis';
            if (n.includes('vocab')) return 'type-voc';
            if (n.includes('reading')) return 'type-read';
            if (n.includes('h w')) return 'type-hw';
            if (n.includes('tongue')) return 'type-tongue';
            if (n.includes('one shot')) return 'type-shot';
            if (n.includes('gp') || n.includes('project')) return 'type-project';
            if (n.includes('role play')) return 'type-role';
            if (n.includes('squeezer') || n.includes('dmt') || n.includes('wish')) return 'type-special';
            
            return 'type-hw'; // الافتراضي
        }

        // Initialize Levels
        const levelContainer = document.getElementById('levelContainer');
