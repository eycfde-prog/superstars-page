<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EYC VETO - Student Portal</title>
    <style>
        :root {
            --sidebar-bg: #0f172a;
            --accent: #10b981;
            --bg-main: #f8fafc;
        }

        body { font-family: 'Segoe UI', sans-serif; margin: 0; display: flex; height: 100vh; background: var(--bg-main); overflow: hidden; }

        /* Sidebar: Level Column */
        .sidebar { width: 240px; background: var(--sidebar-bg); color: white; display: flex; flex-direction: column; overflow-y: auto; box-shadow: 2px 0 10px rgba(0,0,0,0.2); }
        .logo { padding: 25px; font-size: 1.6rem; font-weight: 800; color: var(--accent); border-bottom: 1px solid #1e293b; text-align: center; }
        
        .level-item { border-bottom: 1px solid #1e293b; }
        .level-btn { width: 100%; padding: 18px; background: none; border: none; color: #cbd5e1; text-align: left; cursor: pointer; font-weight: 600; display: flex; justify-content: space-between; }
        .level-btn:hover { background: #1e293b; color: white; }
        .level-btn.active { border-left: 5px solid var(--accent); background: #1e293b; color: var(--accent); }

        /* Drawer: Session Sub-menu */
        .session-drawer { max-height: 0; overflow: hidden; background: #020617; transition: max-height 0.3s ease; }
        .sess-btn { width: 100%; padding: 12px 35px; background: none; border: none; color: #64748b; text-align: left; cursor: pointer; font-size: 0.9rem; }
        .sess-btn:hover { color: white; }
        .sess-btn.active { color: var(--accent); font-weight: bold; }

        /* Content Stage */
        .stage { flex: 1; display: flex; flex-direction: column; overflow-y: auto; padding: 40px; }
        .header-path { font-size: 0.9rem; color: #64748b; margin-bottom: 10px; text-transform: uppercase; }
        .activity-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-top: 20px; }

        /* Dynamic Activity Buttons */
        .act-card { 
            padding: 30px 20px; border-radius: 12px; color: white; font-weight: bold; font-size: 1.1rem;
            cursor: pointer; transition: 0.3s; text-align: center; border: none;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1); display: flex; flex-direction: column; gap: 8px;
        }
        .act-card:hover { transform: translateY(-5px); box-shadow: 0 10px 15px rgba(0,0,0,0.15); filter: brightness(1.1); }
        .act-card small { font-size: 0.7rem; font-weight: normal; opacity: 0.8; text-transform: uppercase; }

        /* Activity Type Colors */
        .type-gr { background: #2563eb; }      /* Grammar */
        .type-lis { background: #7c3aed; }     /* Listening */
        .type-voc { background: #ea580c; }     /* Vocab */
        .type-read { background: #0891b2; }    /* Reading */
        .type-special { background: #be123c; } /* DMT/Squeezer/Wish */
        .type-hw { background: #475569; }      /* H.W */
        .type-tongue { background: #059669; }   /* Tongue Twister */
        .type-shot { background: #db2777; }    /* One Shot */
/* Activity Type Colors */
